if shoot=true {sprite_index=spr_squidflyR2}
}

if right=false
{
if shoot=false {sprite_index=spr_squidflyL1}
if shoot=true {sprite_index=spr_squidflyL2}
}

if obj_doodlebob.x&gt;self.x {right=true}
if obj_doodlebob.x&lt;self.x {right=false}

//randomize clarinet sound effects
csnd[0]=snd_clarinet1
csnd[1]=snd_clarinet2
csnd[2]=snd_clarinet3
clarsound=csnd[random(2)]

//control defeat
if global.bosshealth&lt;=1
{audio_stop_all() global.squidwardboss=true room_goto(rm_squidbeat)}</string>
