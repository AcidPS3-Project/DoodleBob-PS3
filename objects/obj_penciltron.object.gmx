        <arguments>
          <argument>
            <kind>1</kind>
            <string>footshot+=1

if footshot&lt;5
{
audio_play_sound(snd_planktoncharge,1,false)
alarm[2]=(60*2.39)
}

if footshot=5
{
hspeed=0
move_towards_point(xstart,ystart,8)
movebackx=true
movebacky=true
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="2" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>attacknum+=1

if attacknum&lt;5
{attack=choose(1,2,3)}
if attacknum=5
{attack=4 attacknum=0}

//shoot horizontally while hovering up and down
if attack=1
{
obj_penciljetpack.sprite_index=spr_penciljetpack2
vspeed=-8
hspeed=10
audio_play_sound(snd_planktonfly,1,false)
armraise=true
}

//shoot vertically while hovering left and right in the air
if attack=2
{
obj_penciljetpack.sprite_index=spr_penciljetpack2
vspeed=-8
audio_play_sound(snd_planktonfly,1,false)
}

//shoot charged blast from head
if attack=3
{
instance_create(x+156,y+12,obj_deathblast)
instance_create(obj_doodlebob.x,obj_doodlebob.y-40,obj_planktontarget)
}

//shoot homing missiles
if attack=4
{
instance_create(x+186,y+203,obj_homingpencil)
homingshoot=1
alarm[3]=50
reset=true
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//shoot horizontally while flying up and down
//----------------
if self.y&lt;=-200 and vspeed&lt;0 and attack=1 and armshot=0
{
vspeed=0
self.y=-200
obj_pencilarmR.image_single=1
obj_pencilarmL.image_single=1
audio_play_sound(snd_krabsblast,1,false)
instance_create(x+78,y+224,obj_armlaser)
}

if self.y&gt;=0 and vspeed&gt;0 and attack=1 and armshot=1
{vspeed=0
self.y=0
audio_play_sound(snd_krabsblast,1,false)
instance_create(x+78,y+224,obj_armlaser)}

if self.y&gt;=200 and vspeed&gt;0 and attack=1 and armshot=2
{vspeed=0
self.y=200
audio_play_sound(snd_krabsblast,1,false)
instance_create(x+78,y+224,obj_armlaser)}

if armshot=3
{
movebackx=true 
movebacky=true 
hspeed=-10
vspeed=-8
obj_pencilarmR.image_single=0 
obj_pencilarmL.image_single=0
armlower=true
}

if self.x&gt;=(xstart+250) and hspeed&gt;0 and attack=1
{
hspeed=0
self.x=(xstart+250)
}

if armraise=true
{obj_pencilarmL.image_angle-=5 obj_pencilarmR.image_angle-=5}

if obj_pencilarmL.image_angle&lt;=-90
{armraise=false obj_pencilarmL.image_angle=-90 obj_pencilarmR.image_angle=-90}

if armlower=true
{obj_pencilarmL.image_angle+=5 obj_pencilarmR.image_angle+=5}

if obj_pencilarmL.image_angle&gt;=0
{armlower=false obj_pencilarmL.image_angle=0 obj_pencilarmR.image_angle=0}

if (movebackx=true or movebacky=true) and attack=1
{
if x&lt;=xstart
{x=xstart movebackx=false hspeed=0}
if y&lt;=ystart
{y=ystart movebacky=false vspeed=0}
if x&lt;=xstart and y&lt;=ystart
{movebackx=false movebacky=false x=xstart y=ystart hspeed=0 vspeed=0 armshot=0 obj_penciljetpack.sprite_index=spr_penciljetpack alarm[0]=30}
}

//shoot vertically while flying back and forth
//------------------------
if self.y&lt;=-500 and vspeed&lt;0 and attack=2
{
vspeed=0
hspeed=-6
self.y=-500
alarm[1]=60
}

if (movebackx=true or movebacky=true) and attack=2
{
if x&lt;(xstart+5) and x&gt;(xstart-5)
{movebackx=false x=xstart hspeed=0}
if y&lt;(ystart+5) and y&gt;(ystart-5)
{movebacky=false y=ystart vspeed=0}
if x&lt;(xstart+5) and x&gt;(xstart-5) and y&lt;(ystart+5) and y&gt;(ystart-5)
{movebackx=false movebacky=false x=xstart y=ystart hspeed=0 vspeed=0 move_towards_point(x,y,0) footshot=0 movebackx=false movebacky=false obj_penciljetpack.sprite_index=spr_penciljetpack alarm[0]=30}
}

//control homing missiles and when to reset attack
if instance_number(obj_homingpencil)&lt;3 and reset=true
{alarm[0]=(7*60) reset=false}

//control defeat
if global.bosshealth&lt;=0
{audio_stop_all() room_goto(rm_planktonbeat)}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="4" ename="obj_homingpencil">
      <action>
        <libid>1</libid>
