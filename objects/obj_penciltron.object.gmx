        <arguments>
          <argument>
            <kind>1</kind>
            <string>if other.attack=true and hurt=false
{
global.bosshealth-=10
hurt=true 
alarm[4]=5
alarm[6]=60
audio_play_sound(snd_planktonhurt,1,false)
audio_play_sound(choose(snd_planktonhurt1,snd_planktonhurt2,snd_planktonhurt3),1,false)
with(other)instance_destroy()
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
