        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if attack=2
{hspeed=-hspeed}</string>
          </argument>
        </arguments>
      </action>
    </event>
