        <arguments>
          <argument>
            <kind>1</kind>
            <string>if dialogue=1
{draw_sbtext(spr_squidwardcs,4,c_squidblue,0,"DoodleBob! I remember you! I suppose you're here to #beat me up again, huh?")}
if dialogue=2
{draw_sbtext(spr_doodlebobcs,11,c_white,0,"Glockin?")}
if dialogue=3
{draw_sbtext(spr_squidwardcs,4,c_squidblue,0,"Well, you won't ruin my day this time! I finally have hair #again, and I won't let you and SpongeBob screw it up!")}
if dialogue=5
{draw_sbtext(spr_spongebobcs,15,c_yellow,0,"Holy shrimp! You're in big trouble, DoodleBob. Squidward is #normally grumpy, but that Doodle Hairpiece he's wearing has #greater intensified his anger!")}
if dialogue=6
{draw_sbtext(spr_spongebobcs,9,c_yellow,0,"To make matters worse, it has supercharged his clarinet, so #every note he plays is lethal!")}
if dialogue=7
{draw_sbtext(spr_spongebobcs,16,c_yellow,0,"Oh, and in case you haven't already noticed, it gave him #the ability to fly.")}
if dialogue=8
{draw_sbtext(spr_spongebobcs,17,c_yellow,0,"Luckily, your Magic Pencil is all you'll really need for #this battle. Squidward will fly all around the room, while #repeatedly pelting you with Music Notes from his clarinet.")}
if dialogue=9
{draw_sbtext(spr_spongebobcs,17,c_yellow,0,"Every time Squidward blasts a Music Note at you, you'll have #to quickly draw a wall between yourself and the Note, so the #Note will bounce back at Squidward instead of hitting you.")}
if dialogue=10
{draw_sbtext(spr_spongebobcs,17,c_yellow,0,"Be warned, whenever Squidward gets hit by a Music Note, all #the walls you drew will disappear, so get ready to do a lot #of drawing!")}
if dialogue=11
{draw_sbtext(spr_spongebobcs,17,c_yellow,0,"You'll have to hit Squidward about 15 times to defeat him. #Good luck!")}
if dialogue=12
{
    global.mousex=320;
    global.mousey=240;
    obj_debugger.mx=320;
    obj_debugger.my=240;
    audio_stop_all();
    room_goto(rm_squidboss);
}
</string>
