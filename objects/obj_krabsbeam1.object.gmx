c_dollar=make_color_rgb(147,255,147)
alp1=0
alp2=0
alp3=0
alp4=0
nothing=false
audio_play_sound(snd_krabscharge,1,false)
audio_play_sound(snd_krabscontrol,1,false)
</string>
          </argument>
