        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if nothing=false
{
draw_set_color(c_dollar)

if alp1&lt;.8 and !instance_exists(obj_krabsbeam2)
{alp1+=.01};
if instance_exists(obj_krabsbeam2)
{alp1-=.02};

alp2=alp1-.1
alp3=alp2-.1
alp4=alp3-.1

draw_set_alpha(alp1)
draw_circle(self.x,self.y,40,false)
draw_set_alpha(alp2)
draw_circle(self.x,self.y,50,false)
draw_set_alpha(alp3)
draw_circle(self.x,self.y,60,false)
draw_set_alpha(alp4)
draw_circle(self.x,self.y,70,false)

if alp1&gt;=.8 and glow=true
{glow=false
audio_stop_sound(snd_krabscharge)
instance_create(self.x,self.y,obj_krabsbeam2)}
}

draw_set_alpha(1)
draw_sprite(spr_dollar,-1,self.x,self.y)</string>
