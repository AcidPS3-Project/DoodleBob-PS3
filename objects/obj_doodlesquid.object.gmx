    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//if nothing is under you, turn on the gravity
if place_free(self.x,self.y+1)
{vgravity=.5}

//control vgravity
vspeed+=vgravity

//control health
if enemyhealth&lt;=0 and dead=false
{
dead=true
sprite_index=spr_squiderase
audio_play_sound(snd_squiderase,1,false)
image_speed=.1
move=false
}
</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if move=true
{
//acceleration control
if right=false and accel&gt;0
{accel-=.25}

if right=true and accel&lt;0
{accel+=.25}

//-------------------------------------------
//-------------------------------------------

//move right
if right=true
{
//if there's nothing to the right and you are on the ground, move to the right using a loop code
if jump=false
{for (i=-8; i&lt;= 8; i +=1)
{
if place_free(self.x+accel,self.y-i)
{self.x+=accel; self.y-=i; if accel&lt;8 {accel+=.25} exit;}
else
//this prevents wall collision glitches
if !place_free(self.x+8,self.y-20)
{self.x+=0; accel=0; exit;}
if !place_free(self.x+accel,self.y-20)
{self.x+=0; accel=0; exit;}
}}

//if there is nothing to the right and you are jumping, move to the right using a normal movement code (to prevent glitches)
if jump=true
{if place_free(self.x+accel,self.y)
{self.x+=accel if accel&lt;8 {accel+=.25}}
else if place_free(self.x+accel,self.y-8)
{self.x+=accel self.y-=8 move_contact_solid(270,12) if accel&lt;8 {accel+=.25}}}
//this prevents wall collision glitches
if !place_free(self.x+8,self.y-20) and place_free(self.x,self.y+(sprite_get_bbox_top(mask_index)-85))
{self.x+=0; accel=0; exit;}
if !place_free(self.x+accel,self.y-20) and place_free(self.x,self.y+(sprite_get_bbox_top(mask_index)-85))
{self.x+=0; accel=0; exit;}
}

//-------------------------------------------
//-------------------------------------------

//move left
if right=false
{
//if you're pressing Left, right is false
right=false

//if there's nothing to the left and you are on the ground, move to the left using a loop code
if jump=false
{for (i=-8; i&lt;= 8; i +=1)
{
if place_free(self.x+accel,self.y-i)
{self.x+=accel; self.y-=i; if accel&gt;-8 {accel-=.25} exit;}
else
//this prevents wall collision glitches
if !place_free(self.x-8,self.y-20)
{self.x+=0; accel=0; exit;}
if !place_free(self.x+accel,self.y-20)
{self.x+=0; accel=0; exit;}
}}

//if there is nothing to the left and you are jumping, move to the left using a normal movement code (to prevent glitches)
if jump=true
{if place_free(self.x+accel,self.y)
{self.x+=accel if accel&gt;-8 {accel-=.25}}
else if place_free(self.x+accel,self.y-8)
{self.x+=accel self.y-=8 move_contact_solid(270,12) if accel&gt;-8 {accel-=.25}}}
//this prevents wall collision glitches
if !place_free(self.x-8,self.y-20) and place_free(self.x,self.y+(sprite_get_bbox_top(mask_index)-85))
{self.x+=0; accel=0; exit;}
if !place_free(self.x+accel,self.y-20) and place_free(self.x,self.y+(sprite_get_bbox_top(mask_index)-85))
{self.x+=0; accel=0; exit;}
}
}</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="4" ename="obj_floor">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//if the floor is under you, stop moving down
if !place_free(self.x,self.y+(sprite_get_bbox_bottom(mask_index)-85))
{
vspeed=0 
move_contact(270) 
jump=false
vgravity=0
}

//if the floor is above you and there is nothing below, stop moving up and contact the surface of the ceiling
if !place_free(self.x,self.y+(sprite_get_bbox_top(mask_index)-85)) and place_free(self.x,self.y+(sprite_get_bbox_bottom(mask_index)-85))
{
vspeed=0 
move_contact(90)
}

//if the floor is above you and directly below you, stop moving up but don't contact the ceiling.
if !place_free(self.x,self.y+(sprite_get_bbox_top(mask_index)-85)) and !place_free(self.x,self.y+(sprite_get_bbox_bottom(mask_index)-85))
{
vspeed=0 
}</string>
          </argument>
        </arguments>
      </action>
    </event>
