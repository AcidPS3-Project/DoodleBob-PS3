        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>global.hoverenergy=200
global.doublejump=false
global.player=1
global.keycontrol=1
alp=1
global.bosshealth=100
health=100
instance_create(-32,0,obj_invisiwall)
instance_create(room_width,0,obj_invisiwall)
i=192
create=true
if lives&lt;0 {lives=3}

if room=rm_treedome {instance_create(192,room_height/2,obj_glare)}

if room=rm_jellyfishfields {audio_play_sound(msc_jfields,0,true)}
if room=rm_patrickboss {audio_play_sound(msc_patboss,0,true)}
if room=rm_treedome {audio_play_sound(msc_treedome,0,true)}
if room=rm_sandyboss {audio_play_sound(msc_sandyboss,0,true)}
if room=rm_krustykrab {audio_play_sound(msc_krustykrab,0,true)}
if room=rm_squidshouse {audio_play_sound(msc_squidshouse,0,true) instance_create(320,720,obj_squidshouseview)}
if room=rm_squidboss {audio_play_sound(msc_squidboss,0,true) obj_doodlebob.right=false obj_doodlebob.sprite_index=db_standL}
if room=rm_chumbucket {audio_play_sound(msc_chumbucket,0,true)}
if room=rm_planktonboss {audio_play_sound(msc_planktonboss,0,true) instance_create(-32,0,obj_planktonwall) instance_create(room_width,0,obj_planktonwall)}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>instance_activate_object(obj_patcutscene)

if room=rm_treedome
{
if create=true {i+=400}
if i&gt;=room_width and create=true {create=false i=room_width}
if create=true and !instance_position(i,room_height/2,obj_glare) {instance_create(i,room_height/2,obj_glare)}
}</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if !instance_exists(obj_cutsceneparent)
{
draw_sprite(spr_dbhealth,-1,view_xview+10,view_yview+10)
draw_healthbar(view_xview+10,view_yview+32,view_xview+180,view_yview+50,health,c_black,c_gray,c_white,0,true,true)
draw_sprite(spr_dblives,-1,view_xview+10,view_yview+view_hview-10)
draw_sprite(spr_dblnumber,lives,view_xview+65,view_yview+view_hview-10)

if room=rm_patrickboss
{
draw_sprite(spr_pathealth,-1,view_xview+view_wview-10,view_yview+10)
draw_healthbar(view_xview+view_wview-10,view_yview+32,view_xview+view_wview-180,view_yview+50,global.bosshealth,c_black,c_red,c_patpink,0,true,true)
}

if room=rm_sandyboss
{
draw_sprite(spr_sanhealth,-1,view_xview+view_wview-10,view_yview+10)
draw_healthbar(view_xview+view_wview-10,view_yview+32,view_xview+view_wview-180,view_yview+50,global.bosshealth,c_black,c_olive,c_sandybrown,0,true,true)
}

if room=rm_krabsboss
{
draw_sprite(spr_krabshealth,-1,view_xview+view_wview-10,view_yview+10)
draw_healthbar(view_xview+view_wview-10,view_yview+32,view_xview+view_wview-180,view_yview+50,global.bosshealth,c_black,c_sandybrown,c_red,0,true,true)
}

if room=rm_squidboss
{
draw_sprite(spr_squidhealth,-1,view_xview+view_wview-10,view_yview+10)
draw_healthbar(view_xview+view_wview-10,view_yview+32,view_xview+view_wview-180,view_yview+50,global.bosshealth,c_black,c_blue,c_squidblue,0,true,true)
}

if room=rm_planktonboss
{
draw_sprite(spr_plankhealth,-1,view_xview+view_wview-10,view_yview+10)
draw_healthbar(view_xview+view_wview-10,view_yview+32,view_xview+view_wview-180,view_yview+50,global.bosshealth,c_black,c_olive,c_green,0,true,true)
}


if keyboard_check(ord("F"))
{draw_set_font(font0)
draw_set_color(c_black)
draw_text(view_xview+10,view_yview+70,"FPS:"+string(fps)+"#Lives:"+string(lives))
draw_set_color(c_white)}
}</string>
          </argument>
        </arguments>
      </action>
