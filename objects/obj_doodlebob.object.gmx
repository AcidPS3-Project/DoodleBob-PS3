    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//sprite_controls
if jump=false
{
    if right=true
    {
        if accel=0 and !(gamepad_button_check(0,vkright) or gamepad_button_check(0,vkleft)) sprite_index=spr_standR
        else sprite_index=spr_walkR;
    }
    if right=false
    {
        if accel=0 and !(gamepad_button_check(0,vkright) or gamepad_button_check(0,vkleft)) sprite_index=spr_standL
        else sprite_index=spr_walkL;
    }


    if accel&gt;0 image_speed=accel/24
    else if accel&lt;0 image_speed=-accel/24
    else image_speed=0.0000001/24;
}

//if nothing is under you, turn on the gravity
if place_free(x,y+1)
{vgravity=0.5 jump=true}

//control vgravity
vspeed+=vgravity

//if vertical speed is more than 12, don't let it go any higher
if vspeed&gt;12 vspeed=12

//control health and dying
if health&lt;=0 or (self.y-86)&gt;room_height
{
    instance_create(self.x,self.y,obj_dbdead)
    if right=true {obj_dbdead.right=true}; if right=false {obj_dbdead.right=false};
    with(obj_parrow)instance_destroy()
    with(obj_mousecontrol)instance_destroy()
    with(obj_pbeam)instance_destroy()
    with(obj_arm)instance_destroy()
    with(obj_smarrow1)instance_destroy()
    with(obj_smarrow2)instance_destroy()
    with(obj_targeteraser)instance_destroy()
    instance_destroy()
}

//cutscene controls
if self.x&gt;=7140 and room=rm_jellyfishfields and cutscene=false
{
cutscene=true 
with(obj_grounddraw)instance_change(obj_grounddes,true)
instance_create(self.x,self.y,obj_patview)
instance_create(self.x,self.y,obj_dbdummy)
instance_create(self.x,self.y,obj_patcutscene)
instance_destroy()
}

if self.x&gt;=7830 and room=rm_treedome and cutscene=false
{
cutscene=true 
with(obj_grounddraw)instance_change(obj_grounddes,true)
instance_create(self.x,self.y,obj_sandyview)
instance_create(self.x,self.y,obj_dbdummy)
instance_create(self.x,self.y,obj_sandycutscene)
instance_destroy()
}

if self.x&gt;=10144 and room=rm_krustykrab and cutscene=false
{
cutscene=true 
with(obj_grounddraw)instance_change(obj_grounddes,true)
instance_create(self.x,self.y,obj_krabsview)
instance_create(self.x,self.y,obj_dbdummy)
instance_create(self.x,self.y,obj_krabscutscene)
instance_destroy()
}

if self.x&lt;=464 and self.y&lt;480 and room=rm_squidshouse and cutscene=false
{
cutscene=true 
with(obj_grounddraw)instance_change(obj_grounddes,true)
instance_create(self.x,10,obj_squidview)
instance_create(self.x,self.y,obj_dbdummy)
instance_create(self.x,self.y,obj_squidcutscene)
instance_destroy()
}

if self.x&gt;=9088 and room=rm_chumbucket and cutscene=false
{
cutscene=true 
with(obj_grounddraw)instance_change(obj_grounddes,true)
instance_create(self.x,self.y,obj_planktonview)
instance_create(self.x,self.y,obj_dbdummy)
instance_create(self.x,self.y,obj_planktoncutscene)
instance_destroy()
}



//jumping sprites
if jump=true and shooting=false and hover&lt;2
{if right=true {sprite_index=spr_jumpR} else {sprite_index=spr_jumpL}}

//randomize jump sound effects
jsnd+=1; if jsnd&gt;3 {jsnd=1};
if jsnd=1 {jumpsound=snd_bobjump1}
if jsnd=2 {jumpsound=snd_bobjump2}
if jsnd=3 {jumpsound=snd_bobjump3}

//deactivate all objects outside the view
instance_activate_object(self)
instance_deactivate_region(self.x-800,self.y-800,1600,1600,false,true)
instance_activate_region(self.x-800,self.y-800,1600,1600,true)
instance_activate_object(obj_control)
instance_activate_object(obj_arm)
instance_activate_object(obj_targeteraser)
instance_activate_object(obj_pbeam)
instance_activate_object(obj_mousecontrol)
instance_activate_object(obj_parrow)
instance_activate_object(obj_shakes)
instance_activate_object(obj_bubbleexplosion)
instance_activate_object(obj_patview)
instance_activate_object(obj_sandyview)
instance_activate_object(obj_dbteleportin)
instance_activate_object(obj_nutcracker)
instance_activate_object(obj_pause)
instance_activate_object(obj_krabsview)
instance_activate_object(obj_squidshouseview)
instance_activate_object(obj_squidview)
instance_activate_object(obj_penciltron)
instance_activate_object(obj_deathblast)
instance_activate_object(obj_planktontarget)
instance_activate_object(obj_planktonwall)
instance_activate_object(obj_homingpencil)
instance_activate_object(obj_planktonview)
instance_activate_object(obj_debugger)
</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//jumping
if gamepad_button_check_pressed(0,vkup)
{
if !place_free(self.x,self.y+(sprite_get_bbox_bottom(mask_index)-85)) and jump=false
{vspeed=-12 jump=true if (!audio_is_playing(snd_erase) and !audio_is_playing(snd_bobhurt)) {audio_play_sound(jumpsound,1,false)}}
}

//-------------------------------------------
//-------------------------------------------

//acceleration control
if !gamepad_button_check(0,vkright) and accel&gt;0
{accel-=.25}

if !gamepad_button_check(0,vkleft) and accel&lt;0
{accel+=.25}

//-------------------------------------------
//-------------------------------------------

//move right
if gamepad_button_check(0,vkright) and keypress!=1
{
//turn on keypress
keypress=2

//if you're pressing Right, right is true
right=true

//if there's nothing to the right and you are on the ground, move to the right using a loop code
if jump=false
{for (i=-8; i&lt;= 8; i +=1)
{
if place_free(self.x+accel,self.y-i)
{self.x+=accel; self.y-=i; if accel&lt;8 {accel+=.25} exit;}
else
//this prevents wall collision glitches
if !place_free(self.x+8,self.y-20)
{self.x+=0; accel=0; exit;}
if !place_free(self.x+accel,self.y-20)
{self.x+=0; accel=0; exit;}
}}

//if there is nothing to the right and you are jumping, move to the right using a normal movement code (to prevent glitches)
if jump=true
{if place_free(self.x+accel,self.y)
{self.x+=accel if accel&lt;8 {accel+=.25}}
else if place_free(self.x+accel,self.y-8)
{self.x+=accel self.y-=8 move_contact_solid(270,12) if accel&lt;8 {accel+=.25}}}
//this prevents wall collision glitches
if !place_free(self.x+8,self.y-20) and place_free(self.x,self.y+(sprite_get_bbox_top(mask_index)-85))
{self.x+=0; accel=0; exit;}
if !place_free(self.x+accel,self.y-20) and place_free(self.x,self.y+(sprite_get_bbox_top(mask_index)-85))
{self.x+=0; accel=0; exit;}
}

//-------------------------------------------
//-------------------------------------------

//move left
if gamepad_button_check(0,vkleft) and keypress!=2
{
//turn on keypress
keypress=1

//if you're pressing Left, right is false
right=false

//if there's nothing to the left and you are on the ground, move to the left using a loop code
if jump=false
{for (i=-8; i&lt;= 8; i +=1)
{
if place_free(self.x+accel,self.y-i)
{self.x+=accel; self.y-=i; if accel&gt;-8 {accel-=.25} exit;}
else
//this prevents wall collision glitches
if !place_free(self.x-8,self.y-20)
{self.x+=0; accel=0; exit;}
if !place_free(self.x+accel,self.y-20)
{self.x+=0; accel=0; exit;}
}}

//if there is nothing to the left and you are jumping, move to the left using a normal movement code (to prevent glitches)
if jump=true
{if place_free(self.x+accel,self.y)
{self.x+=accel if accel&gt;-8 {accel-=.25}}
else if place_free(self.x+accel,self.y-8)
{self.x+=accel self.y-=8 move_contact_solid(270,12) if accel&gt;-8 {accel-=.25}}}
//this prevents wall collision glitches
if !place_free(self.x-8,self.y-20) and place_free(self.x,self.y+(sprite_get_bbox_top(mask_index)-85))
{self.x+=0; accel=0; exit;}
if !place_free(self.x+accel,self.y-20) and place_free(self.x,self.y+(sprite_get_bbox_top(mask_index)-85))
{self.x+=0; accel=0; exit;}
}

//-------------------------------------------
//-------------------------------------------

//turn off keypress
if !(gamepad_button_check_released(0,vkright) or gamepad_button_check(0,vkleft)) and keypress!=0
{keypress=0}

//-------------------------------------------
//-------------------------------------------

//deceleration
if !gamepad_button_check(0,vkright) and !gamepad_button_check(0,vkleft)
{
//if standing, use loop code
if jump=false
{for (i=-8; i&lt;= 8; i +=1)
{
if place_free(self.x+accel,self.y-i)
{self.x+=accel; self.y-=i; exit;}
//this prevents wall collision glitches
if !place_free(self.x+accel,self.y-20)
{self.x+=0; accel=0 exit;}
}}

//if jumping, use normal code
if jump=true
{if place_free(self.x+accel,self.y)
{self.x+=accel}
else if place_free(self.x+accel,self.y-8)
{self.x+=accel self.y-=8 move_contact_solid(270,12)}}
//this prevents wall collision glitches
if (!place_free(self.x+8,self.y-20) or !place_free(self.x-8,self.y-20)) and place_free(self.x,self.y+(sprite_get_bbox_top(mask_index)-85))
{self.x+=0; accel=0 exit;}
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
