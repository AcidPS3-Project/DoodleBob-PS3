    <event eventtype="4" ename="obj_floor">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//if the floor is under you, stop moving down
if !place_free(self.x,self.y+(sprite_get_bbox_bottom(mask_index)-85))
{
vspeed=0 
move_contact(270) 
jump=false
vgravity=0

if right=true {sprite_index=spr_standR} else {sprite_index=spr_standL}
}

//if the floor is above you and there is nothing below, stop moving up and contact the surface of the ceiling
if !place_free(self.x,self.y+(sprite_get_bbox_top(mask_index)-85)) and place_free(self.x,self.y+(sprite_get_bbox_bottom(mask_index)-85))
{
vspeed=0 
move_contact(90)
}

//if the floor is above you and directly below you, stop moving up but don't contact the ceiling.
if !place_free(self.x,self.y+(sprite_get_bbox_top(mask_index)-85)) and !place_free(self.x,self.y+(sprite_get_bbox_bottom(mask_index)-85))
{
vspeed=0 
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
