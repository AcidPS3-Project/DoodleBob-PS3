  <spriteName>spr_nutcrackerstandR</spriteName>
  <solid>0</solid>
  <visible>-1</visible>
  <depth>-11</depth>
  <persistent>0</persistent>
  <parentName>&lt;undefined&gt;</parentName>
  <maskName>&lt;undefined&gt;</maskName>
  <events>
    <event eventtype="0" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>move=false
punch=false
right=true
image_speed=.25</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//if there is no wall, walk right
if global.wallnumber&lt;=0 and move=false
{
move=true 
hspeed=8 
sprite_index=spr_nutcrackerwalkR 
audio_play_sound(snd_robotfree,1,false)
}

//if you're close to sandy, punch her
if self.x&gt;=(obj_sandy.x-140) and punch=false and hspeed&gt;0
{
punch=true 
hspeed=0 
self.x=(obj_sandy.x-140) 
sprite_index=spr_nutcrackerpunch 
audio_play_sound(snd_robotpunch,1,false)
}

//if sandy is tired, hurt her
if sprite_index=spr_nutcrackerpunch and image_index&gt;2 and image_index&lt;5 and obj_sandy.sprite_index=spr_sandytired and obj_sandy.hurt=false
{
obj_sandy.hurt=true 
global.bosshealth-=20 
audio_play_sound(snd_sandyhurt1,1,false) 
audio_play_sound(snd_robotsmash,1,false) 
obj_sandy.alarm[3]=5 
obj_sandy.alarm[5]=60
}

//if walking left and back at start position, stop moving and start over
if self.x&lt;=xstart and right=false
{
right=true 
self.x=xstart 
sprite_index=spr_nutcrackerstandR 
hspeed=0 
move=false 
punch=false 
obj_robotwall.visible=true 
global.wallnumber=global.wallnumberbu
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="7" enumb="7">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if sprite_index=spr_nutcrackerpunch
{sprite_index=spr_nutcrackerwalkL hspeed=-8 right=false}</string>
          </argument>
        </arguments>
      </action>
    </event>
  </events>
