  <depth>-666</depth>
  <persistent>-1</persistent>
  <parentName>&lt;undefined&gt;</parentName>
  <maskName>&lt;undefined&gt;</maskName>
  <events>
    <event eventtype="0" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>global.mousex=320;
global.mousey=240;
mx=320;
my=240;
global.demo=1;
sns=3;
gmin=0.4;
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if instance_exists(obj_control) room_speed=72 else room_speed=32;
window_set_caption(string(fps));

var stick_rh=gamepad_axis_value(0,gp_axisrh);
var stick_rv=gamepad_axis_value(0,gp_axisrv);
var rup=stick_rv&lt;=-gmin;
var rdown=stick_rv&gt;=gmin;
var rright=stick_rh&gt;=gmin;
var rleft=stick_rh&lt;=-gmin;

var cursor_x = rright-rleft;
var cursor_y = rdown-rup;

mx += cursor_x*(2*sns);
my += cursor_y*(2*sns);

// do not over-use this power of sticks instead of cursor
if mx&lt;0 mx=0; if mx&gt;640 mx=640;
if my&lt;0 my=0; if my&gt;480 my=480;

global.mousex=mx+view_xview[0];
global.mousey=my+view_yview[0];
</string>
          </argument>
        </arguments>
      </action>
    </event>
  </events>
