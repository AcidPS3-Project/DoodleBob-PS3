            <kind>1</kind>
            <string>if dialogue=1
{draw_sbtext(spr_krabscs,1,c_red,0,"Argh! Stay back, landlubber! You'll never get me dollar!")}
if dialogue=2
{draw_sbtext(spr_krabscs,1,c_red,0,"This dollar was a gift from the great King Plankton! #All hail Plankton!")}
if dialogue=3
{draw_sbtext(spr_spongebobcs,1,c_yellow,0,"Barnacles! I should have known Plankton would brainwash #Mr. Krabs using a Doodle Dollar!")}
if dialogue=4
{draw_sbtext(spr_spongebobcs,1,c_yellow,0,"This will be a hard battle, DoodleBob. Mr. Krabs has #always loved money, so that Doodle Dollar has #given him amazing new speed powers.")}
if dialogue=5
{draw_sbtext(spr_spongebobcs,2,c_yellow,0,"Mr. Krabs will start out running toward you. When he reaches #the wall, he will spin into a ball, hover high in the air, #and Homing Attack you a few times.")}
if dialogue=6
{draw_sbtext(spr_spongebobcs,1,c_yellow,0,"Make sure to avoid all his attacks, or he'll shred #through you like a knife!")}
if dialogue=7
{draw_sbtext(spr_spongebobcs,1,c_yellow,0,"He will repeat his whole pattern of attacking you three #times, then he will stop moving and charge up his most #powerful attack, Ketchup Control.")}
if dialogue=8
{draw_sbtext(spr_spongebobcs,2,c_yellow,0,"You can't jump high enough to avoid Ketchup Control on #your own, so you'll have to quickly draw a small platform #above the ground that will help you get higher.")}
if dialogue=9
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"After he uses Ketchup Control, Mr. Krabs will have #to stop and rest for a minute.")}
if dialogue=10
{draw_sbtext(spr_spongebobcs,14,c_yellow,112,"See those burning Krabby Patties that are being made by #the old Krabby O' Mondays machine in the ceiling? Whenever #Mr. Krabs stops to rest, erase the platform containing the Patty #above him. That will make the Patty fall down and burn his #Doodle Dollar!")}
if dialogue=11
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"The Dollar will finally be destroyed after it is burned #five times, which will return Mr. Krabs to normal. ##...I mean, he'll still be obsessed with money, but won't be #evil anymore.")}
if dialogue=12
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"Good luck!")}
if dialogue=13
{audio_stop_all() room_goto(rm_krabsboss)}

if gamepad_button_check_pressed(0,gp_face1) dialogue+=1;
if gamepad_button_check_pressed(0,gp_start)
{
    audio_stop_all();
    room_goto(rm_krabsboss);
}
</string>
