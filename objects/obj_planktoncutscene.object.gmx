    <event eventtype="8" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if dialogue=1
{draw_sbtext(spr_planktoncs,7,c_green,0,"Well well well, if it isn't Sponge... wait, you're not #SpongeBob. Who the scallop are you?")}
if dialogue=2
{draw_sbtext(spr_doodlebobcs,0,c_white,0,"Sheglockin noymin floymin!")}
if dialogue=3
{draw_sbtext(spr_planktoncs,9,c_green,0,"DoodleBob? Ha! SpongeBob was such a wimp, he sent his #own doodle to stop me! How pathetic!")}
if dialogue=4
{draw_sbtext(spr_spongebobcs,19,c_yellow,0,"You can mock all you want, Plankton, but DoodleBob has #destroyed all four Special Doodles, freed my friends from #your mind control, and wiped out your entire doodle army! #It's the end of the line for you!")}
if dialogue=5
{draw_sbtext(spr_planktoncs,10,c_green,0,"Indeed, it seems you have me cornered. I guess I might #as well give up, right?")}
if dialogue=6
{draw_sbtext(spr_spongebobcs,3,c_yellow,0,"Um... right?")}
if dialogue=7
{draw_sbtext(spr_planktoncs,9,c_green,0,"WRONG!")}
if dialogue=8
{draw_sbtext(spr_planktoncs,10,c_green,0,"Karen, download all the data I collected from the Magic #Pencil into my ultimate weapon and activate it now!!")}
if dialogue=9
{draw_sbtext(spr_karencs,0,c_karenpurple,0,"Plankton, that's a bad idea. If anything happens to #your ultimate weapon, all the data you collected will #be lost.")}
if dialogue=10
{draw_sbtext(spr_planktoncs,11,c_green,0,"DO IT!")}
if dialogue=11
{draw_sbtext(spr_karencs,0,c_karenpurple,0,"Whatever, hotshot...")}
if dialogue=13
{draw_sbtext(spr_planktoncs,9,c_green,0,"Mwahaha!!! Behold, my mightiest creation: the Plankton #Penciltron of Power!")}
if dialogue=14
{draw_sbtext(spr_doodlebobcs,7,c_white,0,"Galoobin...")}
if dialogue=15
{draw_sbtext(spr_planktoncs,9,c_green,0,"Bow before me, fool! This grand machine is made of the #same data as your Magic Pencil, so you can't just erase #it like you did my Doodle Army.")}
if dialogue=16
{draw_sbtext(spr_planktoncs,10,c_green,0,"Surrender now, or I'll erase you before you can say #'Shenoymin noymin oymin!'")}
if dialogue=17
{draw_sbtext(spr_doodlebobcs,15,c_white,0,"Nogglah!!!")}
if dialogue=18
{draw_sbtext(spr_planktoncs,9,c_green,0,"So, you still defy me, do you? Then you shall die!")}
if dialogue=19
{draw_sbtext(spr_spongebobcs,5,c_yellow,0,"Holy halibut, it looks like you're in for the fight #of your life, DoodleBob!")}
if dialogue=20
{draw_sbtext(spr_spongebobcs,1,c_yellow,0,"As Plankton already said, you can't use the Magic Pencil #to damage the Penciltron, so you'll have to find some other #way to take him down. Hmm...")}
if dialogue=21
{draw_sbtext(spr_spongebobcs,19,c_yellow,0,"The Penciltron has three powerful attacks you must avoid, #and he does them all in random order. Sometimes he will fly #up and down while shooting massive laser beams to the left. #When he does that, you'll have to jump to avoid the lasers.")}
if dialogue=22
{draw_sbtext(spr_spongebobcs,19,c_yellow,0,"In a different attack, he will fly back and forth high #in the air, and shoot laser beams straight down. You'll #have to run fast to dodge them.")}
if dialogue=23
{draw_sbtext(spr_spongebobcs,1,c_yellow,0,"Once in a while, he will charge up massive energy ball #in his head, and aim it straight at you. Make sure to #avoid it no matter what, or you're toast!")}
if dialogue=24
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"Finally, after he randomly attacks you a few times in #the ways I just mentioned, he will shoot three Homing #Missiles at you. That's your chance to hit him!")}
if dialogue=25
{draw_sbtext(spr_spongebobcs,2,c_yellow,0,"Before you get hit by the Homing Missiles, quickly draw #a wall to bounce them back at the Penciltron. That's the only #way to damage him, so be sure to bounce the missiles #in the right direction!")}
if dialogue=26
{draw_sbtext(spr_planktoncs,11,c_green,0,"Enough talk! It's time for you to die!")}
if dialogue=27
{draw_sbtext(spr_spongebobcs,1,c_yellow,0,"Good luck, DoodleBob!")}
if dialogue=28
{audio_stop_all() room_goto(rm_planktonboss)}</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="9" enumb="32">
