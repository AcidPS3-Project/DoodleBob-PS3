}

if dialogue=13
{
obj_pencildummy.stick=false
obj_pencildummy.hspeed=8
obj_spongebobdummy.sprite_index=sb_grabR
audio_play_sound(snd_acornpower,1,false)
}

if dialogue=20
{
with(obj_smarrow1dummy)instance_destroy()
with(obj_smarrow2dummy)instance_destroy()
with(obj_dbdummy3)instance_change(obj_teleportoutL,true)
obj_pencildummy.sprite_index=spr_pencilteleport
obj_pencildummy.image_index=0
obj_pencildummy.image_speed=1.1
}

if dialogue&gt;0 and dialogue!=7 and dialogue!=14 and keypress=false
{dialogue+=1 keypress=true}
</string>
