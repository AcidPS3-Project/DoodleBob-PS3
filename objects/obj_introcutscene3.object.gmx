        <arguments>
          <argument>
            <kind>1</kind>
            <string>if dialogue=1
{draw_sbtext(spr_spongebobcs,1,c_yellow,0,"Oh, what do I do now? Plankton's right, I don't #stand a chance against his army!")}
if dialogue=2
{draw_sbtext(spr_spongebobcs,2,c_yellow,0,"Hmm... but I might know someone who does!")}
if dialogue=3
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"DoodleBob! He started out a bad guy, but when I #trapped him in this piece of paper a long time #ago, all his negative energy was neutralized, #making him good.")}
if dialogue=4
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"Since he's a doodle, he has a much better chance of #defeating Plankton's Doodle Army. Plus, he's a pro #at using the Magic Pencil! He's the perfect man #for the job!")}
if dialogue=5
{draw_sbtext(spr_spongebobcs,4,c_yellow,0,"Now, how do I get him back out of this paper?")}
if dialogue=6
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"Hmm... maybe the Magic Pencil can do it!")}
if dialogue=8
{draw_sbtext(spr_doodlebobcs,9,c_white,0,"Shoymin oymin noymin?")}
if dialogue=9
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"It worked! Welcome back to the real world, #DoodleBob!")}
if dialogue=10
{draw_sbtext(spr_spongebobcs,13,c_yellow,0,"Um... you're not still mad about that whole #'trapping you in a piece of paper' thing, right?")}
if dialogue=11
{draw_sbtext(spr_doodlebobcs,9,c_white,0,"Nahgommin.")}
if dialogue=12
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"Great! Now, I've got a mission for you. Plankton has created #an army of evil doodles, and has brainwashed my friends. #I need you to destroy the four 'Special Doodles,' so my #friends will be freed from Plankton's mind control #and the Chum Bucket's front door will unlock again.")}
if dialogue=13
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"Here, take the Magic Pencil. You're gonna need it!")}
if dialogue=15
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"The Pencil is your only weapon against Plankton's Army, #so use it wisely.")}
if dialogue=16
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"Use the Left Mouse Button to draw, and #the Right Mouse Button to erase.")}
if dialogue=17
{draw_sbtext(spr_spongebobcs,2,c_yellow,0,"Remember, you can use the pencil to draw bridges #across gaps, erase things you've drawn, or #even erase enemies!")}
if dialogue=18
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"To move yourself around, use the Arrow Keys or #the letters W,A,S,D on the keyboard.")}
if dialogue=19
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"I've installed a radio in that Pencil so I can give you #some more tips later, when you fight Patrick, Sandy, Squidward, #Mr. Krabs, and eventually Plankton himself.")}
if dialogue=20
{draw_sbtext(spr_spongebobcs,2,c_yellow,0,"Good luck, DoodleBob!")}
</string>
          </argument>
        </arguments>
      </action>
