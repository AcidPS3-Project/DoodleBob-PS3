        <arguments>
          <argument>
            <kind>1</kind>
            <string>if dialogue=1
{draw_sbtext(spr_sandycs,0,c_sandybrown,0,"Howdy SpongeBob! How are ya?") obj_sandydummy.sprite_index=spr_sandyL}
if dialogue=2
{draw_sbtext(spr_doodlebobcs,6,c_white,0,"Flabbin gastenokin?")}
if dialogue=3
{draw_sbtext(spr_sandycs,0,c_sandybrown,0,"Oh, you're his friend DoodleBob? Sorry, you and #SpongeBob look a lot alike.")}
if dialogue=4
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"Thank goodness, Sandy's alright!")}
if dialogue=5
{draw_sbtext(spr_sandycs,0,c_sandybrown,0,"'Course I'm alright! Why wouldn't I be?")}
if dialogue=6
{draw_sbtext(spr_doodlebobcs,0,c_white,0,"Hobba fwobba dinnokin shoymin nonna gilluckin #gwippa shinokin noyman!")}
if dialogue=7
{draw_sbtext(spr_sandycs,2,c_sandybrown,0,"Magical pencils? Mind control? Evil doodles? That's #crazy talk! What could a dumb ol' doodle possibly do?")}
if dialogue=8
{draw_sbtext(spr_doodlebobcs,3,c_white,0,"...")}
if dialogue=9
{draw_sbtext(spr_sandycs,3,c_sandybrown,0,"No offense.")}
if dialogue=10
{draw_sbtext(spr_sandycs,0,c_sandybrown,0,"Anyway, ya'll got nothin' to worry about. I haven't seen #any evil doodles all day. I've just been here collecting #acorns for winter. See?") obj_sandydummy.sprite_index=spr_sandyLacorn}
if dialogue=11
{draw_sbtext(spr_doodlebobcs,2,c_white,0,"HOYMINOYMIN!")}
if dialogue=12
{draw_sbtext(spr_spongebobcs,5,c_yellow,0,"Sandy, drop that acorn! It's one of Plankton's doodles!")}
if dialogue=13
{draw_sbtext(spr_sandycs,4,c_sandybrown,0,"Huh, now that ya'll mention it, this here acorn does #seem a bit more white than the rest...")}
if dialogue=14
{draw_sbtext(spr_sandycs,5,c_sandybrown,0,"Ugh, I feel strange... #what's goin' on?")}
if dialogue=16
{draw_sbtext(spr_sandycs,6,c_sandybrown,0,"DIE!")}
if dialogue=17
{draw_sbtext(spr_doodlebobcs,7,c_white,0,"Oh shenoymin...")}
if dialogue=18
{draw_sbtext(spr_spongebobcs,5,c_yellow,0,"Barnacles! Looks like you'll have to fight Sandy #after all, DoodleBob. She's the most powerful enemy you've #ever faced, so you're gonna need some tips.")}
if dialogue=19
{draw_sbtext(spr_spongebobcs,2,c_yellow,0,"Sandy will start out by stomping back and forth a couple times. #She is so tall, you can't jump over her normally, so #you'll have to draw a platform above the ground to #help you get higher.")}
if dialogue=20
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"Next, she will jump around the room a few times. Be careful #to avoid her, or you'll get smashed. When she's jumping around, #you should probably also erase anything you drew, so it #doesn't get in your way.")}
if dialogue=21
{draw_sbtext(spr_spongebobcs,2,c_yellow,0,"Finally, the effects of the Doodle Acorn will wear #off for a few seconds, and Sandy will change back to normal. #That's your chance to attack! When Sandy is normal, #erase the wall that's blocking the Nutcracker robot. #It will damage the acorn for you!")}
if dialogue=22
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"The Doodle Acorn will be destroyed after it's been hit #about 5 times, so get ready for a long, hard battle.")}
if dialogue=23
{draw_sbtext(spr_spongebobcs,0,c_yellow,0,"Good luck!")}
if dialogue=24
{audio_stop_all() room_goto(rm_sandyboss)}</string>
          </argument>
        </arguments>
      </action>
