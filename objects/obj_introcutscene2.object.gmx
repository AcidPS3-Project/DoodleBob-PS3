            <string>if dialogue=1
{draw_sbtext(spr_planktoncs,3,c_green,0,"Feel free to keep that pencil, if you like. You're too #late to stop me now, anyway!")}
if dialogue=2
{draw_sbtext(spr_planktoncs,2,c_green,0,"To make sure you don't mess up my plans again, #I'm creating this special Doodle Door Lock #to keep you out of the Chum Bucket...")}
if dialogue=4
{draw_sbtext(spr_planktoncs,2,c_green,0,"Next, I'm making these four Special Doodles...")}
if dialogue=6
{draw_sbtext(spr_planktoncs,2,c_green,0,"My front door will stay locked forever unless #these four doodles are erased.") create2=true}
if dialogue=7
{draw_sbtext(spr_planktoncs,2,c_green,0,"Of course, to keep you from erasing them, I'm going to #give these Special Doodles to four powerful Guardians #throughout Bikini Bottom, so you'll never get #your grubby hands on them!")}
if dialogue=8
{draw_sbtext(spr_spongebobcs,8,c_yellow,0,"Go ahead and try! I'll find the Guardians, defeat #them all, and destroy those Doodles! Bring it on!")}
if dialogue=9
{draw_sbtext(spr_planktoncs,3,c_green,0,"Oh, did I forget to mention the Guardians will be... your friends?")}
if dialogue=10
{draw_sbtext(spr_spongebobcs,7,c_yellow,0,"Ha! Are you nuts? My friends would never help you!")}
if dialogue=11
{draw_sbtext(spr_planktoncs,3,c_green,0,"I wouldn't be so sure about that. You see, these four #Doodles have a special ingredient: #Professor Plankton's Mind Control Shampoo! #(with conditioner)!")}
if dialogue=12
{draw_sbtext(spr_planktoncs,3,c_green,0,"Now, let's send these to Patrick, Krabs, Sandy, #and Squidward, shall we? Mwahaha!")}
if dialogue=14
{draw_sbtext(spr_spongebobcs,11,c_yellow,0,"NOOOO!")}
if dialogue=15
{draw_sbtext(spr_planktoncs,3,c_green,0,"Yes! As we speak, all your friends are being #brainwashed into serving me! You'll never get those #doodles back, unless you're willing to fight your #little buddies!")}
if dialogue=16
{draw_sbtext(spr_spongebobcs,12,c_yellow,0,"You've gone too far this time, Plankton! I'll stop #you if it's the last thing I do!")}
if dialogue=17
{draw_sbtext(spr_planktoncs,3,c_green,0,"You can run but you can't hide, Spongebrat! #If my army of evil doodles doesn't find you... #your friends will! HAHAHAHA!")}
</string>
          </argument>
        </arguments>
