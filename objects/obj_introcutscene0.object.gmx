        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_sprite(spr_pressspace,-1,room_width-20,room_height-20)

if dialogue=1
{
draw_set_halign(fa_center) 
draw_set_valign(fa_center) 
draw_set_font(fnt_narrator)
draw_set_color(c_yellow)
draw_text(room_width/2,room_height/2,"Our Story Begins #Far in the Future....")
}

if dialogue=2
{draw_text(room_width/2,room_height/2,"You Know, Like #Next Thursday #or Something...")}

if dialogue=3
{
draw_set_halign(fa_left) 
draw_set_valign(fa_top) 
audio_stop_all() 
draw_set_color(c_white)
room_goto(rm_intro)
}

if dialogue&gt;0 and !instance_exists(obj_fadeinintro) and gamepad_button_check_pressed(0,gp_face1) dialogue+=1;
if gamepad_button_check_pressed(0,gp_start)
{
    draw_set_halign(fa_left) 
    draw_set_valign(fa_top) 
    audio_stop_all() 
    draw_set_color(c_white)
    room_goto(rm_levelselect)
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
