            <string>if move=true {hspeed=15}

if self.x&gt;464 and move=true
{hspeed=0 move=false self.x=464}

if dialogue&gt;0 and dialogue!=8 and gamepad_button_check_pressed(0,gp_face1)
{
    if dialogue=3
    {move=true audio_stop_sound(msc_chumbucket) audio_play_sound(snd_recordscratch,1,false)}
    if dialogue=7
    {audio_play_sound(snd_acornpower,1,false) audio_play_sound(msc_chumbucket,0,true)}
    if dialogue=11
    {audio_stop_sound(msc_chumbucket);audio_play_sound(msc_pwned2,1,false)}
    
    dialogue+=1;
}

if gamepad_button_check_pressed(0,gp_start)
{
