        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if dialogue=1
{draw_sbtext(spr_planktoncs,2,c_green,0,"Mwahaha! Plan Z Version 186 is going perfectly! Using #this magic pencil I stole from that artist with an extremely #handsome voice, I have created an army of evil doodles that #will help me conquer the world!")}
if dialogue=2
{draw_sbtext(spr_planktoncs,2,c_green,0,"Who needs the Krabby Patty formula when I've got this baby? #Hahaha!")}
if dialogue=3
{draw_sbtext(spr_planktoncs,2,c_green,0,"Best of all, I've installed powerful security systems all #around the Chum Bucket, so no one can get in here #and stop me!")}
if dialogue=4
{draw_sbtext(spr_spongebobcs,6,c_yellow,0,"Not so fast, Plankton!")}
if dialogue=5
{draw_sbtext(spr_planktoncs,4,c_green,0,"SpongeBob? How the Davy Jones did you get in here? My #security system should have fried you!")}
if dialogue=6
{draw_sbtext(spr_spongebobcs,7,c_yellow,0,"Oh, you left the front door open.")}
if dialogue=7
{draw_sbtext(spr_planktoncs,5,c_green,0,"Barnacles! I knew I was forgetting something!")}
if dialogue=8
{obj_spongebobdummy.sprite_index=sb_grabL obj_pencildummy.move=true obj_pencildummy.image_speed=0; image_index=2}
if dialogue=9
{draw_sbtext(spr_spongebobcs,8,c_yellow,0,"Looks like your plan's been foiled for the 186th #time, Plankton! I've got the Magic Pencil! #You're powerless now!")}
if dialogue=10
{draw_sbtext(spr_planktoncs,1,c_green,0,"Oh, bravo, Spongeboob.")}
if dialogue=11
{draw_sbtext(spr_planktoncs,3,c_green,0,"Unfortunately for you, I've already copied the Magic Pencil's #data into all my machines, so I can keep making as #many evil doodles as I want! I'm unstoppable!")}
if dialogue=12
{draw_sbtext(spr_spongebobcs,9,c_yellow,0,"Oh...")}
if dialogue=13
{draw_sbtext(spr_spongebobcs,10,c_yellow,0,"*Gulp*")}
if dialogue=14
{audio_stop_all() room_goto(rm_intro2)}</string>
          </argument>
        </arguments>
      </action>
