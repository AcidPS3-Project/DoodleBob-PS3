if right=true {sprite_index=spr_sandywalkR}
if right=false {sprite_index=spr_sandywalkL}
}

if jumping=true and jump=true
{
if right=true {sprite_index=spr_sandyjumpR}
if right=false {sprite_index=spr_sandyjumpL}
}

if sprite_index=spr_sandywalkR or sprite_index=spr_sandywalkL
{
if (image_index=1 or image_index=3) {audio_play_sound(snd_sandystomp,1,false)}
}

//control defeat
if global.bosshealth&lt;=0
{audio_stop_all() global.sandyboss=true room_goto(rm_sandybeat)}
</string>
          </argument>
        </arguments>
      </action>
