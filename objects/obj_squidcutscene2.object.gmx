        <arguments>
          <argument>
            <kind>1</kind>
            <string>if dialogue=1
{draw_sbtext(spr_squidwardcs,5,c_squidblue,0,"My hair! You destroyed my hair! AGAIN! Why don't you and #that idiot SpongeBob ever leave me alone?")}
if dialogue=2
{draw_sbtext(spr_spongebobcs,9,c_yellow,0,"But Squidward, that Doodle Hairpiece was sent by Plankton #to control your mind! We had to destroy it!")}
if dialogue=3
{draw_sbtext(spr_squidwardcs,5,c_squidblue,0,"Mind control? What are you blabbering about? I was just #minding my own business, enjoying my new hair and playing #my clarinet when DoodleBob burst in here and messed #everything up!")}
if dialogue=4
{draw_sbtext(spr_spongebobcs,9,c_yellow,0,"Wait... you mean, you weren't being brainwashed at all? #Then why were you in such a bad mood?")}
if dialogue=5
{draw_sbtext(spr_squidwardcs,5,c_squidblue,0,"Because you and DoodleBob ALWAYS put me in a bad mood, #you moron!")}
if dialogue=6
{draw_sbtext(spr_spongebobcs,17,c_yellow,0,"Well, if you weren't being brainwashed, Plankton must have #forgotten to put his Mind Control Shampoo (with conditioner) #in your Doodle Hairpiece, so it gave you special powers #without turning you evil!")}
if dialogue=7
{draw_sbtext(spr_spongebobcs,9,c_yellow,0,"Of course, whether you were being mind controlled or not, #that hairpiece had to be destroyed anyway, so the door to the #Chum Bucket will unlock!")}
if dialogue=8
{draw_sbtext(spr_spongebobcs,10,c_yellow,0,"Don't worry, Squidward! To make it up to you, I'll make you #a new wig out of eyelashes and sea-bear hair!")}
if dialogue=9
{draw_sbtext(spr_squidwardcs,6,c_squidblue,0,"Grrr....")}
if dialogue=10
{draw_sbtext(spr_doodlebobcs,12,c_white,0,"...")}
if dialogue=11
{draw_sbtext(spr_squidwardcs,7,c_squidblue,0,"GET OUT OF MY HOUSE!!!")}
if dialogue=12
{draw_sbtext(spr_doodlebobcs,13,c_white,0,"*gulp*")}

if dialogue=13 and soundplay=false
{audio_stop_all(); soundplay=true; a=audio_play_sound(msc_levelend,1,false) alarm[0]=20 obj_dbdummy2.sprite_index=db_win with(obj_parrowdummy)instance_destroy() with(obj_smarrow1dummy)instance_destroy() with(obj_smarrow2dummy)instance_destroy()}

